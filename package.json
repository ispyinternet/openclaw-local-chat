{
  "name": "chat-desktop",
  "private": true,
  "version": "0.0.0",
  "description": "Local-first desktop chat client for OpenClaw sessions",
  "author": {
    "name": "ispyinternet",
    "email": "ispyinternet@users.noreply.github.com"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "bash -lc 'fuser -k 5173/tcp >/dev/null 2>&1 || true; vite --port 5173 --strictPort'",
    "dev:electron": "npm run -s rebuild:native && wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build && npm run build:electron",
    "rebuild:native": "electron-builder install-app-deps",
    "build:electron": "cross-env NODE_ENV=production electron-builder --config electron-builder.yml",
    "preview": "vite preview",
    "test": "node --test electron/*.test.cjs"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^22.10.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "svelte": "^5.45.2",
    "vite": "^7.3.1",
    "wait-on": "^8.0.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2"
  }
}
